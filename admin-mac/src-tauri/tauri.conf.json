{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Infinitech Admin Mac",
  "version": "0.1.0",
  "identifier": "com.infinitech.admin.mac",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8891"
  },
  "app": {
    "windows": [
      {
        "title": "Infinitech Admin Mac",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"]
  }
}

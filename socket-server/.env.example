# Socket server
SOCKET_PORT=9898

# JWT
JWT_SECRET=replace-with-a-long-random-shared-secret

# Token issuing trust boundary
TOKEN_API_SECRET=

# CORS
# Production-like environments must provide an explicit ALLOWED_ORIGINS list.
ALLOWED_ORIGINS=http://127.0.0.1:8888,http://localhost:8888,http://127.0.0.1:1788,http://localhost:1788,http://127.0.0.1:1798,http://localhost:1798

# HTTP protection
SOCKET_HTTP_REQUEST_TIMEOUT_MS=30000
SOCKET_HTTP_HEADERS_TIMEOUT_MS=35000
SOCKET_HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
SOCKET_HTTP_RATE_LIMIT_WINDOW_MS=60000
SOCKET_HTTP_RATE_LIMIT_MAX=300
SOCKET_HTTP_SLOW_REQUEST_WARN_MS=1500
SOCKET_JSON_BODY_LIMIT_BYTES=1048576
SOCKET_UPLOAD_LIMIT_BYTES=12582912

# Socket.IO tuning
SOCKET_PING_TIMEOUT_MS=20000
SOCKET_PING_INTERVAL_MS=25000
SOCKET_MAX_HTTP_BUFFER_BYTES=4194304
SOCKET_RTC_RING_TIMEOUT_SECONDS=35

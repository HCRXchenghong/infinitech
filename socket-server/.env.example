# Socket server
SOCKET_PORT=9898

# JWT
JWT_SECRET=replace-with-a-long-random-shared-secret

# Token issuing trust boundary
TOKEN_API_SECRET=

# HEIC converter
HEIC_CONVERTER_URL=http://127.0.0.1:9899

# CORS
ALLOWED_ORIGINS=http://127.0.0.1:8888,http://localhost:8888,http://127.0.0.1:3000,http://localhost:3000

# HTTP protection
SOCKET_HTTP_REQUEST_TIMEOUT_MS=30000
SOCKET_HTTP_HEADERS_TIMEOUT_MS=35000
SOCKET_HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
SOCKET_HTTP_RATE_LIMIT_WINDOW_MS=60000
SOCKET_HTTP_RATE_LIMIT_MAX=300
SOCKET_HTTP_SLOW_REQUEST_WARN_MS=1500
SOCKET_JSON_BODY_LIMIT_BYTES=1048576
SOCKET_UPLOAD_LIMIT_BYTES=12582912
SOCKET_READY_MAX_FALLBACK_MESSAGES=5000
SOCKET_READY_MAX_FALLBACK_CHATS=200
SOCKET_READY_MAX_FALLBACK_AGE_MS=259200000
SOCKET_ENABLE_HISTORY_FALLBACK=false
SOCKET_FALLBACK_CHAT_HISTORY_LIMIT=500
SOCKET_FALLBACK_CHAT_LIST_LIMIT=100
SOCKET_FALLBACK_CHAT_RETENTION_MS=2592000000

# Socket.IO tuning
SOCKET_PING_TIMEOUT_MS=20000
SOCKET_PING_INTERVAL_MS=25000
SOCKET_MAX_HTTP_BUFFER_BYTES=4194304

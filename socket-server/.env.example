# Socket Server 环境变量配置

# AI Staff Token
AI_STAFF_TOKEN=your_ai_staff_token_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# HEIC 转换器服务地址
HEIC_CONVERTER_URL=http://192.168.0.103:9899

# CORS 白名单 (多个用逗号分隔)
ALLOWED_ORIGINS=http://192.168.0.103:8888,http://localhost:8888,http://192.168.0.103:3000,http://localhost:3000

# Optional: OpenClaw Gateway passthrough for /ai namespace
OPENCLAW_GATEWAY=http://192.168.0.103:18789
OPENCLAW_TOKEN=

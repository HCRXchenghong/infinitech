{
  "name": "infinitech-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "verify:merchant-types": "npx tsc -p merchant-app/tsconfig.json --noEmit",
    "verify:rider-types": "npx tsc -p rider-app/tsconfig.json --noEmit",
    "verify:user-types": "npx tsc -p user-vue/tsconfig.json --noEmit",
    "verify:app-mobile-types": "npx tsc -p app-mobile/tsconfig.json --noEmit",
    "verify:mobile-types": "npm run verify:merchant-types && npm run verify:rider-types && npm run verify:user-types && npm run verify:app-mobile-types",
    "verify:admin-vue-build": "npm --workspace admin-vue run build",
    "verify:admin-win-types": "npx tsc -p admin-win/tsconfig.json --noEmit",
    "verify:admin-mac-types": "npx tsc -p admin-mac/tsconfig.json --noEmit",
    "verify:admin-win-build": "npm --workspace admin-win run build",
    "verify:admin-mac-build": "npm --workspace admin-mac run build",
    "verify:admin-stack": "npm run verify:admin-vue-build && npm run verify:admin-win-types && npm run verify:admin-mac-types && npm run verify:admin-win-build && npm run verify:admin-mac-build",
    "verify:contracts-tests": "node --test packages/contracts/src/http.test.mjs",
    "verify:domain-core-tests": "node --test packages/domain-core/src/notification-content.test.mjs",
    "verify:admin-core-tests": "node --test packages/admin-core/src/paginated-resources.test.mjs packages/admin-core/src/system-log-resources.test.mjs packages/admin-core/src/payment-center-resources.test.mjs packages/admin-core/src/service-health-resources.test.mjs packages/admin-core/src/official-site-resources.test.mjs packages/admin-core/src/financial-transaction-resources.test.mjs packages/admin-core/src/notification-resources.test.mjs packages/admin-core/src/content-settings-resources.test.mjs packages/admin-core/src/operations-center-resources.test.mjs packages/admin-core/src/dashboard-resources.test.mjs packages/admin-core/src/system-settings-resources.test.mjs packages/admin-core/src/order-resources.test.mjs packages/admin-core/src/user-management-resources.test.mjs packages/admin-core/src/shop-management-resources.test.mjs",
    "verify:client-sdk-tests": "node --test packages/client-sdk/src/mobile-capabilities.test.mjs packages/client-sdk/src/onboarding-invite.test.mjs",
    "verify:go-tests": "cd backend/go && go test ./...",
    "verify:bff-tests": "npm --prefix backend/bff test",
    "verify:socket-check": "npm --prefix socket-server run check",
    "verify:management-tests": "node --test scripts/lib/management/management.test.mjs",
    "verify:backend-runtime": "npm run verify:go-tests && npm run verify:bff-tests && npm run verify:socket-check",
    "verify:modernization": "node scripts/architecture/verify-modernization-baseline.mjs && npm run verify:mobile-types && npm run verify:admin-stack && npm run verify:contracts-tests && npm run verify:domain-core-tests && npm run verify:admin-core-tests && npm run verify:client-sdk-tests && npm run verify:backend-runtime && npm run verify:management-tests"
  },
  "workspaces": [
    "packages/*",
    "admin-vue",
    "admin-win",
    "admin-mac"
  ]
}

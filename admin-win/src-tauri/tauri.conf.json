{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Infinitech Admin Win",
  "version": "1.0.0",
  "identifier": "com.infinitech.admin.win",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8890"
  },
  "app": {
    "windows": [
      {
        "title": "Infinitech Admin Win",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ]
  }
}

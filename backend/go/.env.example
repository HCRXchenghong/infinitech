# Runtime environment
ENV=development

# Service port
GO_API_PORT=1029

# JWT
# Set a real secret that is at least 32 characters long before starting the service.
JWT_SECRET=replace-with-a-long-random-shared-secret
JWT_EXPIRES_IN=7d
SOCKET_SERVER_API_SECRET=replace-with-a-long-random-socket-server-api-secret

# SMS debugging stays disabled by default.
# SMS_DEBUG_EXPOSE_CODE=false
# SMS_DEBUG_ALLOW_CODE_LIST=false
# ENABLE_ADMIN_DEBUG_MODE_SETTINGS=true

# Database
# Production baseline is PostgreSQL. See backend/docker/docker-compose.yml for local infra.
DB_DRIVER=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=yuexiang_user
DB_PASSWORD=replace-with-local-postgres-password
DB_NAME=yuexiang
# DB_DSN=

# Database pool
DB_MAX_OPEN_CONNS=40
DB_MAX_IDLE_CONNS=20
DB_CONN_MAX_LIFETIME_MINUTES=60
DB_CONN_MAX_IDLE_TIME_MINUTES=30

# Redis
REDIS_ENABLED=true
REDIS_REQUIRED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=2550
REDIS_PASSWORD=replace-with-local-redis-password
REDIS_DB=0

# Fixed public landing ports
PUBLIC_LANDING_BASE_URL=http://127.0.0.1:1788
ONBOARDING_INVITE_BASE_URL=http://127.0.0.1:1788
COUPON_CLAIM_LINK_BASE_URL=http://127.0.0.1:1788

# Push delivery worker readiness gate
PUSH_DISPATCH_ENABLED=false
# Production must not use PUSH_DISPATCH_PROVIDER=log.
# PUSH_DISPATCH_PROVIDER=webhook
# PUSH_DISPATCH_WEBHOOK_URL=https://your-push-gateway.example.com/dispatch
# Production must not point webhook dispatch to localhost, private IPs, or internal-only hostnames.
# Optional webhook auth and signing
# PUSH_DISPATCH_WEBHOOK_AUTH_HEADER=Authorization
# PUSH_DISPATCH_WEBHOOK_AUTH_VALUE=Bearer replace-with-provider-token
# PUSH_DISPATCH_WEBHOOK_SECRET=replace-with-shared-secret
# Or use FCM HTTP v1 in production:
# PUSH_DISPATCH_PROVIDER=fcm
# PUSH_DISPATCH_FCM_PROJECT_ID=your-firebase-project-id
# PUSH_DISPATCH_FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# PUSH_DISPATCH_FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# PUSH_DISPATCH_FCM_TOKEN_URL=https://oauth2.googleapis.com/token
# PUSH_DISPATCH_FCM_API_BASE_URL=https://fcm.googleapis.com
PUSH_READY_MAX_QUEUE=5000
PUSH_READY_MAX_QUEUE_AGE_SECONDS=1800

# RTC recording retention and cleanup worker
RTC_RECORDING_RETENTION_HOURS=24
RTC_RETENTION_CLEANUP_ENABLED=true
RTC_RETENTION_CLEANUP_SECONDS=300
RTC_RETENTION_CLEANUP_BATCH_SIZE=200

# HTTP protections
HTTP_SLOW_REQUEST_WARN_MS=1500

# SQLite is only allowed for temporary local development or testing.
# DB_DRIVER=sqlite
# DB_DSN=data/yuexiang.db

# MySQL is legacy-only and should not be used as the production default.
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=yuexiang_user
# DB_PASSWORD=replace-with-local-mysql-password
# DB_NAME=yuexiang
# ALLOW_LEGACY_PRODUCTION_DB_DRIVER=true

# Production example
# ENV=production
# JWT_SECRET=replace-with-a-real-32-char-secret
# DB_DRIVER=postgres
# DB_HOST=your-postgres-host
# DB_PORT=5432
# DB_USER=your-postgres-user
# DB_PASSWORD=your-postgres-password
# DB_NAME=your-postgres-db
# BOOTSTRAP_ADMIN_PASSWORD=replace-with-generated-bootstrap-password
# REDIS_ENABLED=true
# REDIS_REQUIRED=true
# REDIS_HOST=your-redis-host
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# SOCKET_SERVER_API_SECRET=replace-with-a-real-socket-server-api-secret
# PUSH_DISPATCH_ENABLED=true
# PUSH_DISPATCH_PROVIDER=webhook
# PUSH_DISPATCH_WEBHOOK_URL=https://your-push-gateway.example.com/dispatch
# PUSH_DISPATCH_WEBHOOK_AUTH_HEADER=Authorization
# PUSH_DISPATCH_WEBHOOK_AUTH_VALUE=Bearer replace-with-provider-token
# PUSH_DISPATCH_WEBHOOK_SECRET=replace-with-shared-secret

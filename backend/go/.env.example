# 运行环境
ENV=development

# 服务端口
GO_API_PORT=1029

# JWT 配置
# 生产环境必须替换成至少 32 位的真实密钥
JWT_SECRET=yuexiang-dev-secret-key-change-in-production-32chars
JWT_EXPIRES_IN=7d

# 数据库默认走 PostgreSQL，对应 backend/docker/docker-compose.yml
DB_DRIVER=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=yuexiang_user
DB_PASSWORD=yuexiang_password
DB_NAME=yuexiang
# DB_DSN=

# 连接池
DB_MAX_OPEN_CONNS=40
DB_MAX_IDLE_CONNS=20
DB_CONN_MAX_LIFETIME_MINUTES=60
DB_CONN_MAX_IDLE_TIME_MINUTES=30

# Redis
REDIS_ENABLED=true
REDIS_REQUIRED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=2550
REDIS_PASSWORD=
REDIS_DB=0

# SQLite 只允许临时本地开发 / 测试，不允许生产环境使用
# DB_DRIVER=sqlite
# DB_DSN=data/yuexiang.db

# MySQL 只保留历史兼容 / 应急迁移，不作为生产默认路径
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=yuexiang_user
# DB_PASSWORD=yuexiang_password
# DB_NAME=yuexiang
# ALLOW_LEGACY_PRODUCTION_DB_DRIVER=true

# 生产环境示例
# ENV=production
# JWT_SECRET=replace-with-a-real-32-char-secret
# DB_DRIVER=postgres
# DB_HOST=your-postgres-host
# DB_PORT=5432
# DB_USER=your-postgres-user
# DB_PASSWORD=your-postgres-password
# DB_NAME=your-postgres-db
# REDIS_ENABLED=true
# REDIS_REQUIRED=true
# REDIS_HOST=your-redis-host
# REDIS_PORT=6379

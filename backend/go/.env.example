# Runtime environment
ENV=development

# Service port
GO_API_PORT=1029

# JWT
# Production must replace this with a real secret that is at least 32 characters long.
JWT_SECRET=yuexiang-dev-secret-key-change-in-production-32chars
JWT_EXPIRES_IN=7d

# Database
# Production baseline is PostgreSQL. See backend/docker/docker-compose.yml for local infra.
DB_DRIVER=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=yuexiang_user
DB_PASSWORD=yuexiang_password
DB_NAME=yuexiang
# DB_DSN=

# Database pool
DB_MAX_OPEN_CONNS=40
DB_MAX_IDLE_CONNS=20
DB_CONN_MAX_LIFETIME_MINUTES=60
DB_CONN_MAX_IDLE_TIME_MINUTES=30

# Redis
REDIS_ENABLED=true
REDIS_REQUIRED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=2550
REDIS_PASSWORD=
REDIS_DB=0

# Push delivery worker readiness gate
PUSH_DISPATCH_ENABLED=false
PUSH_READY_MAX_QUEUE=5000
PUSH_READY_MAX_QUEUE_AGE_SECONDS=1800

# HTTP protections
HTTP_SLOW_REQUEST_WARN_MS=1500

# SQLite is only allowed for temporary local development or testing.
# DB_DRIVER=sqlite
# DB_DSN=data/yuexiang.db

# MySQL is legacy-only and should not be used as the production default.
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=yuexiang_user
# DB_PASSWORD=yuexiang_password
# DB_NAME=yuexiang
# ALLOW_LEGACY_PRODUCTION_DB_DRIVER=true

# Production example
# ENV=production
# JWT_SECRET=replace-with-a-real-32-char-secret
# DB_DRIVER=postgres
# DB_HOST=your-postgres-host
# DB_PORT=5432
# DB_USER=your-postgres-user
# DB_PASSWORD=your-postgres-password
# DB_NAME=your-postgres-db
# REDIS_ENABLED=true
# REDIS_REQUIRED=true
# REDIS_HOST=your-redis-host
# REDIS_PORT=6379

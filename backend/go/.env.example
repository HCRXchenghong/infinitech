# 环境配置
ENV=development

# 服务器配置
GO_API_PORT=1029

# JWT配置（必需，生产环境必须修改）
# 密钥长度必须至少32个字符
JWT_SECRET=yuexiang-dev-secret-key-change-in-production-32chars
JWT_EXPIRES_IN=7d

# 数据库配置
DB_DRIVER=sqlite
DB_DSN=data/yuexiang.db

# MySQL配置（如果使用MySQL）
# DB_DRIVER=mysql
# DB_HOST=192.168.0.103
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=yuexiang

# Redis配置
REDIS_ENABLED=true
REDIS_HOST=192.168.0.103
REDIS_PORT=2550
REDIS_PASSWORD=

# 生产环境配置示例
# ENV=production
# JWT_SECRET=your-super-secret-key-at-least-32-characters-long-for-production
# DB_DRIVER=mysql
# DB_HOST=your-db-host
# REDIS_ENABLED=true

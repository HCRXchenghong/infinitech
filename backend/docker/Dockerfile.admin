FROM node:20-alpine AS build

WORKDIR /app/admin-vue

COPY admin-vue/package*.json ./
RUN npm ci

COPY admin-vue ./
RUN npm run build

FROM nginx:1.27-alpine

COPY backend/docker/nginx.admin.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/admin-vue/dist /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=15s --timeout=5s --retries=10 CMD wget -qO- http://127.0.0.1/ >/dev/null || exit 1

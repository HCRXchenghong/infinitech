# BFF service
BFF_PORT=25500
NODE_ENV=development

# Upstream services
# Production-like environments must provide explicit GO_API_URL, SOCKET_SERVER_URL, and SOCKET_SERVER_API_SECRET values.
GO_API_URL=http://127.0.0.1:1029
SOCKET_SERVER_URL=http://127.0.0.1:9898
SOCKET_SERVER_API_SECRET=

# Database compatibility settings
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=yuexiang_user
DB_PASSWORD=replace-with-local-postgres-password
DB_NAME=yuexiang
DB_DIALECT=postgres

# Redis
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=2550
REDIS_PASSWORD=
REDIS_DB=0

# Token secrets
JWT_SECRET=replace-with-a-long-random-business-jwt-secret
ADMIN_TOKEN_SECRET=replace-with-a-long-random-admin-token-secret
ADMIN_QR_LOGIN_SECRET=replace-with-a-long-random-admin-qr-login-secret
JWT_EXPIRES_IN=7d
ADMIN_WEB_BASE_URL=http://127.0.0.1:8888
SITE_WEB_BASE_URL=http://127.0.0.1:1888
# Production must set BFF_CORS_ORIGINS (or explicit admin/site base URLs) and SOCKET_SERVER_API_SECRET.
ALLOWED_ORIGINS=http://127.0.0.1:8888,http://localhost:8888,http://127.0.0.1:1888,http://localhost:1888,http://127.0.0.1:1788,http://localhost:1788

# Sensitive admin mutations stay disabled until both values are configured.
# ENABLE_ADMIN_DEBUG_MODE_SETTINGS=true
# SYSTEM_LOG_DELETE_ACCOUNT=replace-with-operator-account
# SYSTEM_LOG_DELETE_PASSWORD=replace-with-strong-secondary-secret
# CLEAR_ALL_DATA_VERIFY_ACCOUNT=replace-with-dedicated-clear-all-operator-account
# CLEAR_ALL_DATA_VERIFY_PASSWORD=replace-with-dedicated-clear-all-secondary-secret
# FINANCIAL_LOG_VERIFY_ACCOUNT=replace-with-operator-account
# FINANCIAL_LOG_VERIFY_PASSWORD=replace-with-strong-secondary-secret

# Empty DB bootstrap admin. Docker 一键部署会自动生成并写入运行时 env。
# BOOTSTRAP_ADMIN_PHONE=13800138000
# BOOTSTRAP_ADMIN_NAME=Bootstrap Admin
# BOOTSTRAP_ADMIN_PASSWORD=replace-with-generated-password

# Global API rate limit
BFF_API_RATE_LIMIT_WINDOW_MS=60000
BFF_API_RATE_LIMIT_MAX=3000
BFF_REDIS_RATE_LIMIT_ENABLED=false
BFF_REDIS_RATE_LIMIT_PREFIX=ratelimit:bff:api
BFF_REDIS_RATE_LIMIT_CONNECT_TIMEOUT_MS=1000

# Body and upload limits
BFF_JSON_LIMIT_BYTES=1048576
BFF_URLENCODED_LIMIT_BYTES=1048576
BFF_UPLOAD_MAX_FILE_SIZE_BYTES=10485760
BFF_UPLOAD_MAX_FIELD_SIZE_BYTES=65536
BFF_UPLOAD_MAX_FILES=1

# HTTP protection
BFF_REQUEST_TIMEOUT_MS=30000
BFF_HEADERS_TIMEOUT_MS=35000
BFF_KEEP_ALIVE_TIMEOUT_MS=5000
BFF_SLOW_REQUEST_WARN_MS=1500
BFF_READY_REQUIRE_SOCKET=true

# Logging
LOG_LEVEL=info

# BFF 服务配置
BFF_PORT=25500
NODE_ENV=development

# Go 后端服务地址
GO_API_URL=http://192.168.0.103:1029

# 数据库配置
DB_HOST=192.168.0.103
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=yuexiang
DB_DIALECT=mysql

# Redis 配置

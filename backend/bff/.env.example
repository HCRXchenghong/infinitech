# BFF 服务配置
BFF_PORT=25500
NODE_ENV=development

# Go 后端服务地址
GO_API_URL=http://127.0.0.1:1029

# Socket 实时服务地址
SOCKET_SERVER_URL=http://127.0.0.1:9898

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=yuexiang_user
DB_PASSWORD=yuexiang_password
DB_NAME=yuexiang
DB_DIALECT=postgres

# Redis 配置
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=2550
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置
JWT_SECRET=replace-with-a-long-random-shared-secret
JWT_EXPIRES_IN=7d

# 全局 API 限流
BFF_API_RATE_LIMIT_WINDOW_MS=60000
BFF_API_RATE_LIMIT_MAX=3000
BFF_REDIS_RATE_LIMIT_ENABLED=false
BFF_REDIS_RATE_LIMIT_PREFIX=ratelimit:bff:api
BFF_REDIS_RATE_LIMIT_CONNECT_TIMEOUT_MS=1000

# 请求体和上传限制
BFF_JSON_LIMIT_BYTES=1048576
BFF_URLENCODED_LIMIT_BYTES=1048576
BFF_UPLOAD_MAX_FILE_SIZE_BYTES=10485760
BFF_UPLOAD_MAX_FIELD_SIZE_BYTES=65536
BFF_UPLOAD_MAX_FILES=1

# HTTP 超时
BFF_REQUEST_TIMEOUT_MS=30000
BFF_HEADERS_TIMEOUT_MS=35000
BFF_KEEP_ALIVE_TIMEOUT_MS=5000

# 日志级别
LOG_LEVEL=info
